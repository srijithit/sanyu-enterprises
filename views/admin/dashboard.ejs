<!DOCTYPE html>
<html lang="en">
<%- include('../partials/head') %>
<style>
/* ═══ ADMIN SPECIFIC STYLES ═══ */
.admin-subbar {
  position: fixed; top: 64px; left: 0; right: 0; z-index: 100; height: 52px;
  background: var(--dark-2); border-bottom: 1px solid rgba(255,255,255,0.05);
  display: flex; align-items: center; justify-content: space-between; padding: 0 48px;
}
.admin-breadcrumb {
  display: flex; align-items: center; gap: 8px; font-family: 'JetBrains Mono', monospace;
  font-size: 0.7rem; color: var(--text-muted);
}
.admin-breadcrumb .sep { color: var(--text-muted); opacity: 0.4; }
.admin-breadcrumb .current { color: var(--gold-light); }

.admin-body { padding: calc(64px + 52px + 40px) 48px 80px; max-width: 1200px; margin: 0 auto; }

.stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-bottom: 52px; }
.stat-card {
  background: var(--dark-2); border: 1px solid rgba(255,255,255,0.05);
  border-radius: var(--radius-lg); padding: 24px;
}
.stat-card-title { font-size: 0.7rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 8px; }
.stat-card-val { font-family: 'Cormorant Garamond', serif; font-size: 2rem; color: var(--cream); line-height: 1; }

.add-card {
  background: var(--dark-2); border: 1px solid rgba(200,150,12,0.14);
  border-radius: var(--radius-lg); padding: 36px 40px; margin-bottom: 52px; position: relative; overflow: hidden;
}
.add-card::before {
  content: ''; position: absolute; top: 0; right: 0; width: 300px; height: 300px;
  background: radial-gradient(circle at top right, rgba(200,150,12,0.06) 0%, transparent 70%); pointer-events: none;
}
.add-card-header {
  display: flex; align-items: center; gap: 14px; margin-bottom: 28px; padding-bottom: 20px; border-bottom: 1px solid rgba(255,255,255,0.05);
}
.add-card-icon {
  width: 40px; height: 40px; background: rgba(200,150,12,0.12);
  border: 1px solid rgba(200,150,12,0.2); border-radius: var(--radius);
  display: flex; align-items: center; justify-content: center; color: var(--gold);
}
.add-card-title { font-family: 'Cormorant Garamond', serif; font-size: 1.5rem; font-weight: 600; color: var(--cream); }
.add-card-subtitle { font-size: 0.75rem; color: var(--text-muted); margin-top: 1px; }

.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; }
.field { margin-bottom: 20px; }
.field label { display: block; font-size: 0.68rem; font-weight: 700; color: var(--text-muted); letter-spacing: 0.15em; text-transform: uppercase; margin-bottom: 8px; }
.field input, .field textarea, .field select {
  width: 100%; padding: 12px 16px; background: var(--dark-3); border: 1px solid rgba(255,255,255,0.07);
  border-radius: var(--radius-sm); color: var(--text); font-family: 'Syne', sans-serif; font-size: 0.88rem; outline: none; transition: all 0.2s;
}
.field input:focus, .field textarea:focus { border-color: rgba(200,150,12,0.5); background: var(--dark-4); }

.checkbox-wrap { display: flex; align-items: center; gap: 10px; margin-top: 10px; }
.checkbox-wrap input[type=checkbox] { width: auto; }

.img-upload-zone {
  border: 1px dashed rgba(200,150,12,0.25); border-radius: var(--radius); background: var(--dark-3);
  padding: 30px 20px; text-align: center; cursor: pointer; transition: all 0.2s; position: relative;
  min-height: 140px; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 10px;
}
.img-upload-zone:hover { border-color: rgba(200,150,12,0.5); background: rgba(200,150,12,0.04); }
.img-upload-zone input[type=file] { position: absolute; inset: 0; opacity: 0; cursor: pointer; width: 100%; }
.upload-icon { width: 40px; height: 40px; background: rgba(200,150,12,0.1); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: var(--gold); }
.upload-label { font-size: 0.78rem; color: var(--text-dim); font-weight: 500; }
.img-preview-thumb { width: 72px; height: 72px; object-fit: cover; border-radius: var(--radius); display: none; border: 1px solid rgba(255,255,255,0.1); }

/* ═══ TABLE ═══ */
.admin-table-title { font-family: 'Cormorant Garamond', serif; font-size: 1.5rem; font-weight: 600; color: var(--cream); margin-bottom: 20px; }
.table-wrap { overflow-x: auto; background: var(--dark-2); border: 1px solid rgba(255,255,255,0.05); border-radius: var(--radius-lg); }
.products-table { width: 100%; border-collapse: separate; border-spacing: 0; min-width: 800px; }
.products-table th {
  background: var(--dark-3); padding: 11px 16px; font-family: 'JetBrains Mono', monospace; font-size: 0.64rem;
  font-weight: 400; color: var(--text-muted); letter-spacing: 0.12em; text-transform: uppercase; border-bottom: 1px solid rgba(255,255,255,0.05); text-align: left;
}
.products-table td { padding: 14px 16px; border-bottom: 1px solid rgba(255,255,255,0.03); vertical-align: middle; font-size: 0.84rem; }
.products-table tr:last-child td { border-bottom: none; }
.table-img { width: 48px; height: 48px; object-fit: cover; border-radius: var(--radius-sm); border: 1px solid rgba(255,255,255,0.07); }
.action-btns { display: flex; gap: 6px; }
.action-btn { padding: 5px 13px; border-radius: var(--radius-sm); font-size: 0.7rem; font-weight: 700; cursor: pointer; border: none; font-family: 'Syne', sans-serif; text-transform: uppercase; }
.edit-btn { background: rgba(200,150,12,0.1); color: var(--gold-light); border: 1px solid rgba(200,150,12,0.22); }
.del-btn { background: rgba(201,64,64,0.08); color: #c47070; border: 1px solid rgba(201,64,64,0.2); }

/* ═══ MODALS ═══ */
.modal-backdrop {
  position: fixed; inset: 0; background: rgba(0,0,0,0.75); backdrop-filter: blur(6px); z-index: 300; display: none; align-items: center; justify-content: center; padding: 24px;
}
.modal-backdrop.open { display: flex; }
.modal {
  background: var(--dark-2); border: 1px solid rgba(200,150,12,0.18); border-radius: var(--radius-lg); padding: 40px; width: 100%; max-width: 520px; box-shadow: 0 40px 120px rgba(0,0,0,0.8);
}
.modal-title { font-family: 'Cormorant Garamond', serif; font-size: 1.5rem; font-weight: 600; color: var(--cream); margin-bottom: 24px; }
.modal-actions { display: flex; gap: 12px; margin-top: 28px; }
.modal-actions button { flex: 1; }
.btn-cancel { padding: 13px; background: transparent; border: 1px solid rgba(255,255,255,0.08); color: var(--text-dim); border-radius: var(--radius-sm); font-family: 'Syne', sans-serif; font-size: 0.8rem; font-weight: 600; text-transform: uppercase; cursor: pointer; }
.btn-danger { padding: 13px; background: var(--red); color: #fff; border: none; border-radius: var(--radius-sm); font-family: 'Syne', sans-serif; font-size: 0.8rem; font-weight: 800; text-transform: uppercase; cursor: pointer; }

@media (max-width: 768px) {
  .admin-subbar { padding: 0 20px; }
  .admin-body { padding: calc(64px + 52px + 24px) 20px 60px; }
  .form-row { grid-template-columns: 1fr; }
  .add-card { padding: 24px; }
}
</style>
<body>
  <%- include('../partials/nav') %>
  
  <div class="admin-subbar">
    <div class="admin-breadcrumb">
      <span>Sanyu Enterprises</span>
      <span class="sep">/</span>
      <span class="current">Admin Dashboard</span>
    </div>
  </div>

  <div class="admin-body">
    <!-- STATS -->
    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-card-title">Total Products</div>
        <div class="stat-card-val"><%= stats.total %></div>
      </div>
      <div class="stat-card">
        <div class="stat-card-title">Categories</div>
        <div class="stat-card-val"><%= stats.categories %></div>
      </div>
      <div class="stat-card">
        <div class="stat-card-title">Added This Week</div>
        <div class="stat-card-val"><%= stats.recentWeek %></div>
      </div>
    </div>

    <!-- ADD PRODUCT -->
    <div class="add-card">
      <div class="add-card-header">
        <div class="add-card-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14"/></svg>
        </div>
        <div>
          <div class="add-card-title">Add New Product</div>
          <div class="add-card-subtitle">Fill in the details below to list a new item</div>
        </div>
      </div>

      <form id="add-product-form" onsubmit="addProduct(event)">
        <div class="field">
          <label>Product Name *</label>
          <input type="text" name="name" placeholder="e.g. Premium Cotton T-Shirt" required>
        </div>
        <div class="form-row">
          <div class="field">
            <label>Price (INR) *</label>
            <input type="number" name="price" placeholder="e.g. 999" min="0" required>
          </div>
          <div class="field">
            <label>Category</label>
            <input type="text" name="category" placeholder="e.g. Clothing, Electronics">
          </div>
        </div>
        <div class="field">
          <label>Description</label>
          <textarea name="description" placeholder="Brief product description..."></textarea>
        </div>
        
        <div class="form-row">
          <div class="field">
            <label>Product Image Upload (Vercel Blob)</label>
            <div class="img-upload-zone">
              <input type="file" id="add-img" name="image" accept="image/*">
              <img id="img-preview" class="img-preview-thumb" alt="preview">
              <div class="upload-icon" id="upload-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 14.899A7 7 0 1115.71 8h1.79a4.5 4.5 0 012.5 8.242"/><path d="M12 12v9"/><path d="M8 17l4-5 4 5"/></svg>
              </div>
              <div class="upload-label" id="upload-text">Click or drag to upload</div>
              <div style="font-size: 0.68rem; color: var(--text-muted);">PNG, JPG, WEBP — max 5MB</div>
            </div>
          </div>
          
          <div class="field">
            <label>OR External Image URL</label>
            <input type="url" name="image_url" placeholder="https://example.com/image.jpg">
            <div style="font-size: 0.68rem; color: var(--text-muted); margin-top: 8px;">Upload above or paste URL here.</div>
            
            <div class="checkbox-wrap" style="margin-top: 24px;">
              <input type="checkbox" name="featured" id="add-featured">
              <label for="add-featured" style="margin:0; text-transform:none; letter-spacing:0; font-size:0.8rem;">Feature this product on homepage</label>
            </div>
          </div>
        </div>
        
        <button type="submit" class="btn-primary" style="max-width:200px;">Add Product →</button>
      </form>
    </div>

    <!-- PRODUCT LIST -->
    <div class="admin-table-title">Inventory</div>
    <div class="table-wrap">
      <table class="products-table">
        <thead>
          <tr>
            <th>Image</th>
            <th>Product</th>
            <th>Category</th>
            <th>Price</th>
            <th>Featured</th>
            <th>Added</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if (products.length === 0) { %>
            <tr><td colspan="7" style="text-align: center; padding: 40px; color: var(--text-muted);">No products in inventory.</td></tr>
          <% } else { %>
            <% products.forEach(p => { %>
              <tr data-id="<%= p.id %>" data-name="<%= p.name %>" data-price="<%= p.price %>" data-category="<%= p.category %>" data-desc="<%= p.description %>" data-image="<%= p.image_url %>" data-featured="<%= p.featured %>">
                <td>
                  <% if (p.image_url) { %>
                    <img src="<%= p.image_url %>" class="table-img">
                  <% } else { %>
                    <div class="table-img" style="display:flex;align-items:center;justify-content:center;background:var(--dark-4);color:var(--text-muted)"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"><rect x="3" y="3" width="18" height="18" rx="2"/></svg></div>
                  <% } %>
                </td>
                <td>
                  <div style="font-weight: 600; color: var(--cream);"><%= p.name %></div>
                  <div style="font-size: 0.73rem; color: var(--text-muted); max-width: 220px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"><%= p.description %></div>
                </td>
                <td><span style="display:inline-block;padding:2px 10px;background:rgba(200,150,12,0.08);border:1px solid rgba(200,150,12,0.15);border-radius:40px;font-size:0.68rem;color:var(--gold-light);"><%= p.category %></span></td>
                <td><span style="font-size: 0.6rem; color: var(--text-muted);">INR</span> <span style="color: var(--gold-light); font-weight: 700;"><%= Number(p.price).toLocaleString('en-IN') %></span></td>
                <td><%= p.featured ? 'Yes' : 'No' %></td>
                <td style="font-size: 0.72rem; color: var(--text-muted); font-family: 'JetBrains Mono', monospace;"><%= new Date(p.created_at).toLocaleDateString() %></td>
                <td>
                  <div class="action-btns">
                    <button class="action-btn edit-btn" onclick="openEdit(<%= p.id %>)">Edit</button>
                    <button class="action-btn del-btn" onclick="confirmDelete(<%= p.id %>)">Delete</button>
                  </div>
                </td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- MODALS -->
  <div class="modal-backdrop" id="delete-modal">
    <div class="modal" style="max-width:400px; text-align: center;">
      <div style="width: 56px; height: 56px; background: rgba(201,64,64,0.08); border: 1px solid rgba(201,64,64,0.25); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px; color: #c47070;">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/></svg>
      </div>
      <h3 style="font-family: 'Cormorant Garamond', serif; font-size: 1.4rem; color: var(--cream); margin-bottom: 8px;">Delete Product?</h3>
      <p style="font-size: 0.82rem; color: var(--text-muted); line-height: 1.6;">This cannot be undone. The product will be permanently removed.</p>
      
      <input type="hidden" id="delete-target-id">
      <div class="modal-actions">
        <button class="btn-cancel" onclick="closeModal('delete-modal')">Cancel</button>
        <button class="btn-danger" onclick="executeDelete(event)">Delete</button>
      </div>
    </div>
  </div>

  <div class="modal-backdrop" id="edit-modal">
    <div class="modal">
      <div class="modal-title">Edit Product</div>
      <form id="edit-product-form" onsubmit="event.preventDefault(); saveEdit(event);">
        <input type="hidden" id="edit-id">
        <div class="field">
          <label>Product Name *</label>
          <input type="text" name="name" id="edit-name" required>
        </div>
        <div class="form-row">
          <div class="field">
            <label>Price (INR) *</label>
            <input type="number" name="price" id="edit-price" min="0" required>
          </div>
          <div class="field">
            <label>Category</label>
            <input type="text" name="category" id="edit-cat">
          </div>
        </div>
        <div class="field">
          <label>Description</label>
          <textarea name="description" id="edit-desc"></textarea>
        </div>
        <div class="field">
          <label>Replace Image <span style="color:var(--text-muted);text-transform:none;font-weight:400;">(optional)</span></label>
          <div class="img-upload-zone" style="min-height:100px;">
            <input type="file" id="edit-img" name="image" accept="image/*">
            <img id="edit-img-preview" class="img-preview-thumb" alt="preview">
            <div class="upload-label">Click to upload new image</div>
          </div>
        </div>
        <div class="field">
          <label>OR Change Image URL</label>
          <input type="url" name="image_url" id="edit-image-url" placeholder="https://example.com/new-image.jpg">
          <div class="checkbox-wrap" style="margin-top: 16px;">
            <input type="checkbox" name="featured" id="edit-featured">
            <label for="edit-featured" style="margin:0; text-transform:none; letter-spacing:0; font-size:0.8rem;">Feature this product</label>
          </div>
        </div>
        <div class="modal-actions">
          <button type="button" class="btn-cancel" onclick="closeModal('edit-modal')">Cancel</button>
          <button type="submit" class="btn-primary">Save Changes</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Load admin specific scripts -->
  <script src="/js/admin.js"></script>
</body>
</html>
