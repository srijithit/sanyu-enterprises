<!DOCTYPE html>
<html lang="en">
<%- include('partials/head') %>
<body>
  <%- include('partials/nav') %>
  
  <main>
    <section class="hero">
      <div class="hero-bg">
        <div class="hero-bg-circle"></div>
        <div class="hero-bg-circle"></div>
        <div class="hero-grid-lines"></div>
      </div>
      <div class="hero-content">
        <div class="hero-eyebrow">
          <div class="hero-eyebrow-line"></div>
          <span class="hero-eyebrow-text">Welcome to Sanyu Enterprises</span>
        </div>
        <h1 class="hero-title">
          <span>Quality</span>
          <strong>Products</strong>
          <em>Delivered with Care</em>
        </h1>
        <p class="hero-subtitle">Browse our curated selection of premium goods. Order instantly via WhatsApp — fast, simple, reliable.</p>
        <div class="hero-actions">
          <a href="/catalog" class="btn-hero-primary">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
            Browse Catalog
          </a>
          <a href="/catalog" class="btn-hero-secondary">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Order via WhatsApp
          </a>
        </div>
      </div>
      <div class="hero-stat-row">
        <div class="hero-stat">
          <div class="hero-stat-num"><%= totalProducts %></div>
          <div class="hero-stat-label">Products</div>
        </div>
        <div class="hero-stat">
          <div class="hero-stat-num"><%= totalCategories %></div>
          <div class="hero-stat-label">Categories</div>
        </div>
      </div>
    </section>

    <section class="section-padding">
      <div class="section-header">
        <div>
          <div class="section-label">Featured</div>
          <h2 class="section-title">Our <span>Favorites</span></h2>
        </div>
      </div>

      <div class="product-grid">
        <% if (products.length === 0) { %>
          <div class="empty-state">
            <div class="empty-state-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" width="32" height="32">
                <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
                <line x1="3" y1="6" x2="21" y2="6"/>
              </svg>
            </div>
            <h3>No products yet</h3>
            <p>Products will appear here once added to the catalogue.</p>
          </div>
        <% } else { %>
          <% products.forEach(p => { %>
            <a href="/product/<%= p.id %>" class="product-card">
              <div class="product-img-wrap">
                <% if (p.image_url) { %>
                  <img src="<%= p.image_url %>" alt="<%= p.name %>" loading="lazy">
                <% } else { %>
                  <div class="product-img-placeholder">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" width="36" height="36" style="opacity:0.2">
                      <rect x="3" y="3" width="18" height="18" rx="2"/>
                      <circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/>
                    </svg>
                    <span style="font-size:0.7rem;letter-spacing:0.1em;text-transform:uppercase;opacity:0.4">No image</span>
                  </div>
                <% } %>
                <div class="product-category-pill"><%= p.category %></div>
              </div>
              <div class="product-body">
                <div class="product-name"><%= p.name %></div>
                <% if (p.description) { %>
                  <div class="product-desc"><%= p.description %></div>
                <% } %>
                <div class="product-footer">
                  <div class="product-price">
                    <span class="product-price-currency">INR</span>
                    <%= Number(p.price).toLocaleString('en-IN') %>
                  </div>
                  <div style="display:flex; gap: 6px;">
                    <button type="button" class="add-cart-btn" style="background: var(--gold); color: #000; border-color: var(--gold); padding: 9px 14px;" onclick="event.preventDefault(); buyNow(<%= p.id %>, '<%= p.name.replace(/'/g, "\\'") %>', <%= p.price %>, '<%= p.image_url || '' %>')">
                      Buy
                    </button>
                    <button type="button" class="add-cart-btn" style="padding: 9px 14px;" onclick="event.preventDefault(); addToCart(<%= p.id %>, '<%= p.name.replace(/'/g, "\\'") %>', <%= p.price %>, '<%= p.image_url || '' %>')">
                      +
                    </button>
                  </div>
                </div>
              </div>
            </a>
          <% }) %>
        <% } %>
      </div>
      
      <% if (products.length > 0) { %>
        <div style="text-align: center; margin-top: 50px;">
          <a href="/catalog" class="btn-hero-secondary" style="border: 1px solid rgba(255,255,255,0.1); padding: 12px 24px; border-radius: 40px;">
            View Full Collection →
          </a>
        </div>
      <% } %>
    </section>
  </main>

  <%- include('partials/footer') %>
</body>
</html>
