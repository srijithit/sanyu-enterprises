<!DOCTYPE html>
<html lang="en">
<%- include('partials/head') %>
<style>
.cart-layout {
  display: grid; grid-template-columns: 1fr 400px; gap: 40px;
  max-width: 1200px; margin: 0 auto;
}
.cart-items-section {
  background: var(--dark-2); border: 1px solid rgba(255,255,255,0.05);
  border-radius: var(--radius-lg); padding: 32px;
}
.cart-item {
  display: flex; gap: 20px; padding: 20px 0; border-bottom: 1px solid rgba(255,255,255,0.05);
}
.cart-item:last-child { border-bottom: none; padding-bottom: 0; }
.cart-item-img {
  width: 80px; height: 80px; object-fit: cover; border-radius: var(--radius);
  background: var(--dark-3); border: 1px solid rgba(255,255,255,0.05);
}
.cart-item-info { flex: 1; }
.cart-item-name { font-family: 'Cormorant Garamond', serif; font-size: 1.2rem; color: var(--cream); margin-bottom: 4px; }
.cart-item-price { color: var(--gold); font-family: 'JetBrains Mono', monospace; font-size: 0.9rem; }
.cart-item-controls {
  display: flex; align-items: center; gap: 16px; margin-top: 12px;
}
.qty-btn {
  background: var(--dark-3); border: 1px solid rgba(255,255,255,0.1);
  color: var(--text); width: 28px; height: 28px; border-radius: 4px;
  display: flex; align-items: center; justify-content: center; cursor: pointer;
}
.qty-btn:hover { background: var(--dark-4); }
.remove-btn { color: #c47070; font-size: 0.8rem; cursor: pointer; background: none; border: none; text-decoration: underline; }

.checkout-section {
  background: var(--dark-2); border: 1px solid rgba(249, 115, 22,0.15);
  border-radius: var(--radius-lg); padding: 32px; position: sticky; top: 100px;
}
.checkout-title {
  font-family: 'Cormorant Garamond', serif; font-size: 1.5rem; color: var(--cream);
  margin-bottom: 24px; border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 16px;
}
.checkout-summary-row {
  display: flex; justify-content: space-between; margin-bottom: 16px; color: var(--text-dim);
}
.checkout-total {
  display: flex; justify-content: space-between; margin-bottom: 24px;
  font-family: 'Cormorant Garamond', serif; font-size: 1.5rem; color: var(--gold); font-weight: 700;
  border-top: 1px solid rgba(255,255,255,0.05); padding-top: 16px;
}

/* Form Styles */
.field { margin-bottom: 16px; }
.field label {
  display: block; font-size: 0.7rem; font-weight: 700; color: var(--text-muted);
  letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 8px;
}
.field input, .field textarea {
  width: 100%; padding: 12px 16px; background: var(--dark-3);
  border: 1px solid rgba(255,255,255,0.07); border-radius: var(--radius-sm);
  color: var(--text); font-family: 'Syne', sans-serif; font-size: 16px; /* 16px prevents iOS zoom */
  outline: none; transition: border-color 0.2s;
}
.field input:focus, .field textarea:focus { border-color: var(--gold); }
.field textarea { resize: vertical; min-height: 80px; }

.geo-btn {
  background: rgba(249, 115, 22,0.1); color: var(--gold-light);
  border: 1px solid rgba(249, 115, 22,0.3); padding: 8px 12px; border-radius: var(--radius-sm);
  font-size: 0.75rem; cursor: pointer; display: inline-flex; align-items: center; gap: 6px;
  margin-bottom: 8px; transition: background 0.2s;
}
.geo-btn:hover { background: rgba(249, 115, 22,0.2); }

@media (max-width: 900px) {
  .cart-layout { grid-template-columns: 1fr; }
  .checkout-section { position: relative; top: 0; }
}
</style>
<body>
  <%- include('partials/nav') %>
  
  <main>
    <section class="section-padding" style="padding-top: 100px;">
      <div class="section-header">
        <div>
          <div class="section-label">Your Order</div>
          <h1 class="section-title">Shopping <span>Cart</span></h1>
        </div>
      </div>

      <div class="cart-layout" id="cart-container">
        <!-- Rendered by JS -->
      </div>
    </section>
  </main>

  <%- include('partials/footer') %>

  <script>
    const WA_NUM = '<%= whatsappNumber %>';
    
    function renderCartPage() {
      const container = document.getElementById('cart-container');
      
      if (cart.length === 0) {
        container.innerHTML = `
          <div class="empty-state" style="grid-column: 1 / -1;">
            <div class="empty-state-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" width="32" height="32">
                <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/>
              </svg>
            </div>
            <h3>Your cart is empty</h3>
            <p>Looks like you haven't added any items to your cart yet.</p>
            <a href="/catalog" class="btn-primary" style="max-width: 200px; margin-top: 16px;">Browse Products</a>
          </div>
        `;
        return;
      }

      let subtotal = 0;
      let itemsHtml = '<div class="cart-items-section">';
      
      cart.forEach((item, index) => {
        subtotal += item.price * item.quantity;
        itemsHtml += `
          <div class="cart-item">
            ${item.image ? `<img src="${item.image}" class="cart-item-img">` : `<div class="cart-item-img" style="display:flex;align-items:center;justify-content:center;color:var(--text-muted)"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"><rect x="3" y="3" width="18" height="18" rx="2"/></svg></div>`}
            <div class="cart-item-info">
              <div class="cart-item-name">${item.name}</div>
              <div class="cart-item-price">INR ${Number(item.price).toLocaleString('en-IN')}</div>
              <div class="cart-item-controls">
                <div style="display:flex;align-items:center;gap:10px;">
                  <button class="qty-btn" onclick="updateQty(${index}, -1)">-</button>
                  <span style="font-family:'JetBrains Mono',monospace;font-size:0.9rem;">${item.quantity}</span>
                  <button class="qty-btn" onclick="updateQty(${index}, 1)">+</button>
                </div>
                <button class="remove-btn" onclick="removeItem(${index})">Remove</button>
              </div>
            </div>
          </div>
        `;
      });
      itemsHtml += '</div>';

      const checkoutHtml = `
        <div class="checkout-section">
          <h2 class="checkout-title">Order Summary</h2>
          <div class="checkout-summary-row">
            <span>Subtotal</span>
            <span style="font-family:'JetBrains Mono',monospace;">INR ${Number(subtotal).toLocaleString('en-IN')}</span>
          </div>
          <div class="checkout-summary-row">
            <span>Shipping</span>
            <span>Calculated later</span>
          </div>
          <div class="checkout-total">
            <span>Total</span>
            <span>INR ${Number(subtotal).toLocaleString('en-IN')}</span>
          </div>

          <div style="margin-top: 32px;">
            <h3 style="font-size: 1rem; color: var(--cream); margin-bottom: 16px;">Customer Details</h3>
            <div class="field">
              <label>Full Name *</label>
              <input type="text" id="cust-name" placeholder="Enter your name">
            </div>
            <div class="field">
              <label>Phone Number *</label>
              <input type="tel" id="cust-phone" placeholder="Enter your phone number">
            </div>
            <div class="field">
              <label>Delivery Address *</label>
              <button class="geo-btn" onclick="getLocation()" type="button" id="geo-btn-id">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                Use Current Location
              </button>
              <textarea id="cust-address" placeholder="Enter full delivery address"></textarea>
            </div>
            
            <button class="btn-primary" style="background: rgba(37, 211, 102, 0.15); border: 1px solid rgba(37,211,102,0.4); color: #4cde87; box-shadow: none; margin-top: 16px;" onclick="checkoutWA()">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              Complete Order via WhatsApp
            </button>
          </div>
        </div>
      `;

      container.innerHTML = itemsHtml + checkoutHtml;
    }

    function updateQty(index, change) {
      cart[index].quantity += change;
      if (cart[index].quantity < 1) cart[index].quantity = 1;
      saveCart();
      renderCartPage();
    }

    function removeItem(index) {
      cart.splice(index, 1);
      saveCart();
      renderCartPage();
    }

    function getLocation() {
      const btn = document.getElementById('geo-btn-id');
      const addr = document.getElementById('cust-address');
      
      if (!navigator.geolocation) {
        alert("Geolocation is not supported by your browser");
        return;
      }

      btn.textContent = "Locating...";
      
      navigator.geolocation.getCurrentPosition(async (position) => {
        const lat = position.coords.latitude;
        const lon = position.coords.longitude;
        try {
          const res = await fetch(`https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lon}`);
          const data = await res.json();
          if (data && data.display_name) {
            addr.value = data.display_name;
            btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg> Location Found';
          }
        } catch (e) {
          alert("Could not fetch address details.");
          btn.textContent = "Use Current Location";
        }
      }, () => {
        alert("Unable to retrieve your location. Please ensure location permissions are granted.");
        btn.textContent = "Use Current Location";
      });
    }

    function checkoutWA() {
      const name = document.getElementById('cust-name').value.trim();
      const phone = document.getElementById('cust-phone').value.trim();
      const address = document.getElementById('cust-address').value.trim();

      if (!name || !phone || !address) {
        alert('Please fill in your Name, Phone, and Address.');
        return;
      }

      let subtotal = 0;
      let msg = `Hello Sanyu Enterprises! 👋\n\nI would like to place an order:\n\n*🛒 ORDER DETAILS:*\n`;
      
      cart.forEach(item => {
        subtotal += item.price * item.quantity;
        msg += `▪ ${item.name} (x${item.quantity}) - INR ${Number(item.price * item.quantity).toLocaleString('en-IN')}\n`;
      });
      
      msg += `\n*💰 TOTAL AMOUNT: INR ${Number(subtotal).toLocaleString('en-IN')}*\n\n`;
      msg += `*👤 CUSTOMER DETAILS:*\n`;
      msg += `Name: ${name}\nPhone: ${phone}\nAddress: ${address}\n\n`;
      msg += `Please confirm my order. Thank you!`;

      window.open(`https://wa.me/${WA_NUM}?text=${encodeURIComponent(msg)}`, '_blank');
    }

    document.addEventListener('DOMContentLoaded', renderCartPage);
  </script>
</body>
</html>
