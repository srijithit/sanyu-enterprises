<!DOCTYPE html>
<html lang="en">
<%- include('partials/head') %>
<style>
.product-detail-layout {
  display: grid; grid-template-columns: 1fr 1fr; gap: 60px;
  max-width: 1200px; margin: 0 auto;
}
.detail-img-col {
  position: sticky; top: 100px;
}
.detail-img-wrap {
  width: 100%; aspect-ratio: 4/5; background: var(--dark-3);
  border: 1px solid rgba(255,255,255,0.05); border-radius: var(--radius-lg);
  overflow: hidden; display: flex; align-items: center; justify-content: center;
}
.detail-img-wrap img {
  width: 100%; height: 100%; object-fit: cover;
}
.detail-info-col {
  padding: 20px 0;
}
.detail-cat {
  font-family: 'JetBrains Mono', monospace; font-size: 0.75rem;
  color: var(--gold-light); letter-spacing: 0.15em; text-transform: uppercase;
  margin-bottom: 12px; display: inline-block;
  padding: 4px 12px; border: 1px solid rgba(200,150,12,0.3); border-radius: 40px;
}
.detail-title {
  font-family: 'Cormorant Garamond', serif; font-size: 3rem;
  font-weight: 300; color: var(--cream); line-height: 1.1; margin-bottom: 24px;
}
.detail-price {
  font-family: 'Cormorant Garamond', serif; font-size: 2.5rem;
  font-weight: 700; color: var(--gold); margin-bottom: 32px;
  display: flex; align-items: baseline; gap: 8px;
}
.detail-price span {
  font-family: 'JetBrains Mono', monospace; font-size: 1rem;
  color: var(--text-muted); font-weight: 400; text-transform: uppercase;
}
.detail-desc {
  font-size: 1rem; color: var(--text-dim); line-height: 1.8;
  margin-bottom: 40px; font-weight: 400;
}
.detail-actions {
  display: flex; gap: 16px; flex-wrap: wrap;
}
.detail-actions > * { flex: 1; min-width: 200px; }

@media (max-width: 900px) {
  .product-detail-layout { grid-template-columns: 1fr; gap: 40px; }
  .detail-img-col { position: relative; top: 0; }
  .detail-title { font-size: 2.2rem; }
}
</style>
<body>
  <%- include('partials/nav') %>
  
  <main>
    <section class="section-padding" style="padding-top: 100px;">
      
      <div style="margin-bottom: 30px; font-family: 'JetBrains Mono', monospace; font-size: 0.75rem;">
        <a href="/catalog" style="color: var(--text-muted); text-decoration: none;">← Back to Catalog</a>
      </div>

      <div class="product-detail-layout">
        <div class="detail-img-col">
          <div class="detail-img-wrap">
            <% if (product.image_url) { %>
              <img src="<%= product.image_url %>" alt="<%= product.name %>">
            <% } else { %>
              <div class="product-img-placeholder" style="color: var(--text-muted);">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" width="64" height="64" style="opacity:0.2">
                  <rect x="3" y="3" width="18" height="18" rx="2"/>
                  <circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/>
                </svg>
                <span style="font-size:0.8rem;letter-spacing:0.1em;text-transform:uppercase;opacity:0.4">No image available</span>
              </div>
            <% } %>
          </div>
        </div>
        
        <div class="detail-info-col">
          <div class="detail-cat"><%= product.category %></div>
          <h1 class="detail-title"><%= product.name %></h1>
          
          <div class="detail-price">
            <span>INR</span> <%= Number(product.price).toLocaleString('en-IN') %>
          </div>
          
          <% if (product.description) { %>
            <div class="detail-desc">
              <%= product.description.replace(/\n/g, '<br>') %>
            </div>
          <% } %>
          
          <div class="detail-actions">
            <button class="btn-primary" style="background: transparent; border: 1px solid var(--gold); color: var(--gold);" onclick="addToCart(<%= product.id %>, '<%= product.name.replace(/'/g, "\\'") %>', <%= product.price %>, '<%= product.image_url || '' %>')">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/></svg>
              Add to Cart
            </button>
            
            <a href="https://wa.me/<%= whatsappNumber %>?text=<%= encodeURIComponent(`Hello! I'm interested in ordering:\n\n*${product.name}*\nPrice: INR ${Number(product.price).toLocaleString('en-IN')}\n\nPlease let me know if it's available.`) %>" target="_blank" class="btn-primary" style="background: rgba(37, 211, 102, 0.15); border: 1px solid rgba(37,211,102,0.4); color: #4cde87; box-shadow: none;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              Order via WhatsApp
            </a>
          </div>
        </div>
      </div>
    </section>

    <% if (relatedProducts && relatedProducts.length > 0) { %>
      <section class="section-padding">
        <div class="section-header">
          <div>
            <div class="section-label">More in <%= product.category %></div>
            <h2 class="section-title">Related <span>Products</span></h2>
          </div>
        </div>
        <div class="product-grid">
          <% relatedProducts.forEach(p => { %>
            <a href="/product/<%= p.id %>" class="product-card">
              <div class="product-img-wrap">
                <% if (p.image_url) { %>
                  <img src="<%= p.image_url %>" alt="<%= p.name %>" loading="lazy">
                <% } else { %>
                  <div class="product-img-placeholder">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" width="36" height="36" style="opacity:0.2">
                      <rect x="3" y="3" width="18" height="18" rx="2"/>
                      <circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/>
                    </svg>
                  </div>
                <% } %>
              </div>
              <div class="product-body">
                <div class="product-name"><%= p.name %></div>
                <div class="product-footer">
                  <div class="product-price">
                    <span class="product-price-currency">INR</span>
                    <%= Number(p.price).toLocaleString('en-IN') %>
                  </div>
                </div>
              </div>
            </a>
          <% }) %>
        </div>
      </section>
    <% } %>
  </main>

  <%- include('partials/footer') %>
</body>
</html>
